# Copie este arquivo para .env.local e preencha com suas credenciais do Supabase

# Encontre em: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (NUNCA exponha no frontend - apenas .env.local)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Nome do bucket no Supabase Storage para anexos
SUPABASE_STORAGE_BUCKET=anexos
